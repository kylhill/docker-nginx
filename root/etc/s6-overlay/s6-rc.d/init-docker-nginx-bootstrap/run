#!/usr/bin/with-contenv bash
# shellcheck shell=bash
set -Eeuo pipefail

# make folders
mkdir -p \
    /config/geoip \
    /config/keys \
    /config/nginx/site-confs

# Keep QUIC stateless reset and address-validation tokens valid across nginx
# reloads and container replacements that reuse /config.
quic_host_key=/config/keys/quic_host.key
if [ ! -e "${quic_host_key}" ]; then
    echo "Generating persistent QUIC host key..."
    quic_host_key_tmp="${quic_host_key}.tmp.$$"
    (umask 077; head -c 32 /dev/urandom > "${quic_host_key_tmp}")
    mv "${quic_host_key_tmp}" "${quic_host_key}"
fi
chmod 600 "${quic_host_key}"

certificate=/config/keys/cert.crt
private_key=/config/keys/cert.key

if [[ -f "${certificate}" && -f "${private_key}" ]]; then
    echo "Using TLS certificate and key found in /config/keys."
else
    echo "Generating a self-signed TLS certificate in /config/keys."
    if ! rm -f "${certificate}" "${private_key}"; then
        echo "ERROR: Unable to remove incomplete TLS certificate files." >&2
        exit 1
    fi
    umask 077
    if ! openssl req -new -x509 -days 3650 -nodes \
            -out "${certificate}" \
            -keyout "${private_key}" \
            -subj "/CN=localhost" \
            -addext "subjectAltName=DNS:localhost"; then
        rm -f "${certificate}" "${private_key}" || true
        echo "ERROR: Unable to generate the self-signed TLS certificate." >&2
        exit 1
    fi
fi
