#!/usr/bin/with-contenv bash
# shellcheck shell=bash
set -Eeuo pipefail

resolver_conf=/run/nginx/resolver.conf
resolver_override=/config/nginx/snippets/resolver-override.conf

mkdir -p "$(dirname "${resolver_conf}")"

if [ -e "${resolver_override}" ]; then
    if [ ! -f "${resolver_override}" ] || [ ! -r "${resolver_override}" ]; then
        echo "ERROR: Resolver override is not a readable regular file: ${resolver_override}" >&2
        exit 1
    fi
    echo "Using persistent nginx resolver override from ${resolver_override}."
    cp "${resolver_override}" "${resolver_conf}"
else
    resolver_servers="$(awk '
        $1 == "nameserver" {
            server = $2
            if (index(server, ":") != 0) {
                server = "[" server "]"
            }
            printf "%s%s", separator, server
            separator = " "
        }
    ' /etc/resolv.conf)"
    if [ -z "${resolver_servers}" ]; then
        resolver_servers=127.0.0.11
        echo "WARNING: /etc/resolv.conf contained no nameservers; using ${resolver_servers}."
    fi

    echo "Generating nginx runtime resolver configuration from /etc/resolv.conf..."
    {
        echo "## Generated from the container's /etc/resolv.conf at startup."
        echo "resolver ${resolver_servers} ipv6=off valid=300s;"
        echo "resolver_timeout 2s;"
    } > "${resolver_conf}"
fi
