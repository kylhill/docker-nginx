#!/usr/bin/with-contenv bash
# shellcheck shell=bash
set -e

# Keep generated bouncer credentials private to the container user.
umask 077

startup_error() {
    echo "ERROR: $*" >&2
    printf '1\n' > /run/s6-linux-init-container-results/exitcode
    /run/s6/basedir/bin/halt
    return 1
}

read_secret() {
    local var="$1"
    local file_var="${var}_FILE"
    local value="${!var:-}"
    local secret_file="${!file_var:-}"

    if [[ -n "${value}" && -n "${secret_file}" ]]; then
        startup_error "Set either ${var} or ${file_var}, not both."
        return 1
    fi
    if [[ -n "${secret_file}" ]]; then
        if [[ ! -f "${secret_file}" || ! -r "${secret_file}" ]]; then
            startup_error "${file_var} does not reference a readable regular file: ${secret_file}"
            return 1
        fi
        if ! cat "${secret_file}"; then
            startup_error "Unable to read the file referenced by ${file_var}: ${secret_file}"
            return 1
        fi
    else
        printf '%s' "${value}"
    fi
}

API_KEY="$(read_secret CROWDSEC_NGINX_API_KEY)"
BOUNCER_CONF=/run/crowdsec/crowdsec-nginx-bouncer.conf
BOUNCER_CONF_TEMPLATE=/etc/crowdsec/bouncers/crowdsec-nginx-bouncer.conf.template
NGINX_CROWDSEC_INCLUDE=/config/nginx/http.d/crowdsec.conf
NGINX_CROWDSEC_INCLUDE_DEFAULT=/defaults/nginx/templates/crowdsec.conf

rm -f "${NGINX_CROWDSEC_INCLUDE}" "${BOUNCER_CONF}"

if [ -n "${API_KEY}" ] && [ -n "${CROWDSEC_LAPI_URL:-}" ]; then
    echo "Configuring CrowdSec nginx bouncer..."
    mkdir -p /config/nginx/http.d /run/crowdsec

    # The nginx include is static. The bouncer config needs runtime secrets.
    awk \
        -v api_url="${CROWDSEC_LAPI_URL}" \
        -v api_key="${API_KEY}" \
        -v appsec_url="${CROWDSEC_APPSEC_URL:-}" \
        'BEGIN { appsec_written = 0 }
         /^API_URL=/ { print "API_URL=" api_url; next }
         /^API_KEY=/ { print "API_KEY=" api_key; next }
         /^CAPTCHA_PROVIDER=/ { print "CAPTCHA_PROVIDER="; next }
         /^MODE=/ { print "MODE=stream"; next }
         /^REQUEST_TIMEOUT=/ { print "REQUEST_TIMEOUT=500"; next }
         /^APPSEC_URL=/ {
             appsec_written = 1
             if (appsec_url != "") {
                 print "APPSEC_URL=" appsec_url
             } else {
                 print
             }
             next
         }
         { print }
         END {
             if (appsec_url != "" && appsec_written == 0) {
                 print "APPSEC_URL=" appsec_url
             }
         }' \
        "${BOUNCER_CONF_TEMPLATE}" \
        > "${BOUNCER_CONF}"

    if [[ -z ${LSIO_NON_ROOT_USER} ]]; then
        chown abc:abc "${BOUNCER_CONF}"
    fi
    chmod 0600 "${BOUNCER_CONF}"
    install -m 0644 "${NGINX_CROWDSEC_INCLUDE_DEFAULT}" "${NGINX_CROWDSEC_INCLUDE}"
else
    echo "CrowdSec credentials not set, nginx bouncer disabled."
fi
