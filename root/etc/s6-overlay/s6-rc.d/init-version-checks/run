#!/usr/bin/with-contenv bash
# shellcheck shell=bash
set -Eeuo pipefail

version_mismatches=""
while IFS= read -r -d '' active_config; do
    sample_config="${active_config}.sample"
    if [ ! -f "${sample_config}" ]; then
        continue
    fi

    # A sample only adds value when the persisted active config differs from
    # the image default. Remove exact matches after the comparison sample has
    # been refreshed by init-samples.
    if cmp -s "${active_config}" "${sample_config}"; then
        rm -f "${sample_config}"
        continue
    fi

    active_version="$(sed -nE 's|^## Version ([0-9]{4}/[0-9]{2}/[0-9]{2}).*|\1|p' "${active_config}")"
    sample_version="$(sed -nE 's|^## Version ([0-9]{4}/[0-9]{2}/[0-9]{2}).*|\1|p' "${sample_config}")"
    if [ "${active_version}" != "${sample_version}" ]; then
        version_mismatches+="│ $(printf '%10s' "${active_version:-missing}") │ $(printf '%10s' "${sample_version:-missing}") │ $(printf '%-70s' "${active_config}") │\n"
    fi
done < <(find /config/nginx -type f -name '*.conf' -print0)

if [ -n "${version_mismatches}" ]; then
    echo "**** The following active configs have different version dates than the shipped samples. ****"
    echo "**** This may be due to user customization or an update to the samples. ****"
    echo "**** Compare each file with the .sample in the same directory and reconcile changes manually. ****"
    echo "┌────────────┬────────────┬────────────────────────────────────────────────────────────────────────┐"
    echo "│  old date  │  new date  │ path                                                                   │"
    echo "├────────────┼────────────┼────────────────────────────────────────────────────────────────────────┤"
    echo -e "${version_mismatches%\\n}"
    echo "└────────────┴────────────┴────────────────────────────────────────────────────────────────────────┘"
fi

ignored_site_configs=""
while IFS= read -r -d '' site_config; do
    ignored_site_configs+="  ${site_config}\n"
done < <(find /config/nginx/site-confs \
    -type f \
    ! -name '*.subdomain.conf' \
    ! -name '*.conf.sample' \
    -print0)

if [ -n "${ignored_site_configs}" ]; then
    echo "**** The following site configs are ignored because their names do not end in .subdomain.conf: ****"
    echo -e "${ignored_site_configs%\\n}"
    echo "**** Rename each enabled site config to match *.subdomain.conf. ****"
fi
