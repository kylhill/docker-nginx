#!/usr/bin/with-contenv bash
# shellcheck shell=bash
set -e

read_secret() {
    var="$1"
    file_var="${var}_FILE"

    if [ -n "${!file_var}" ] && [ -f "${!file_var}" ]; then
        cat "${!file_var}"
    else
        echo "${!var}"
    fi
}

API_KEY="$(read_secret CROWDSEC_NGINX_API_KEY)"

if [ -n "${API_KEY}" ] && [ -n "${CROWDSEC_LAPI_URL:-}" ]; then
    echo "Configuring CrowdSec nginx bouncer..."

    sed \
        -e "s|\${CROWDSEC_LAPI_URL}|${CROWDSEC_LAPI_URL}|g" \
        -e "s|\${API_KEY}|${API_KEY}|g" \
        /etc/crowdsec/bouncers/crowdsec-nginx-bouncer.conf.template \
        > /etc/crowdsec/bouncers/crowdsec-nginx-bouncer.conf

    # disable captcha - use ban-only remediation
    sed -i "s|^CAPTCHA_PROVIDER=.*|CAPTCHA_PROVIDER=|" \
        /etc/crowdsec/bouncers/crowdsec-nginx-bouncer.conf

    if [ -n "${CROWDSEC_APPSEC_URL:-}" ]; then
        sed -i "s|^APPSEC_URL=.*|APPSEC_URL=${CROWDSEC_APPSEC_URL}|" \
            /etc/crowdsec/bouncers/crowdsec-nginx-bouncer.conf
    fi
else
    echo "CrowdSec credentials not set, skipping bouncer configuration."
fi
