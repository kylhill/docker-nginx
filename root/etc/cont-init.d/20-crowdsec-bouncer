#!/usr/bin/with-contenv bash
# shellcheck shell=bash
set -e

read_secret() {
    var="$1"
    file_var="${var}_FILE"

    if [ -n "${!file_var}" ] && [ -f "${!file_var}" ]; then
        cat "${!file_var}"
    else
        echo "${!var}"
    fi
}

API_KEY="$(read_secret CROWDSEC_NGINX_API_KEY)"
NGINX_CROWDSEC_CONF="/config/nginx/http.d/crowdsec.conf"

if [ -n "${API_KEY}" ] && [ -n "${CROWDSEC_LAPI_URL:-}" ]; then
    echo "Configuring CrowdSec nginx bouncer..."

    mkdir -p /config/nginx/http.d

    sed \
        -e "s|\${CROWDSEC_LAPI_URL}|${CROWDSEC_LAPI_URL}|g" \
        -e "s|\${API_KEY}|${API_KEY}|g" \
        /etc/crowdsec/bouncers/crowdsec-nginx-bouncer.conf.template \
        > /etc/crowdsec/bouncers/crowdsec-nginx-bouncer.conf

    # disable captcha - use ban-only remediation
    sed -i "s|^CAPTCHA_PROVIDER=.*|CAPTCHA_PROVIDER=|" \
        /etc/crowdsec/bouncers/crowdsec-nginx-bouncer.conf

    # stream mode: local cache lookup per-request, no per-request LAPI calls
    sed -i "s|^MODE=.*|MODE=stream|" \
        /etc/crowdsec/bouncers/crowdsec-nginx-bouncer.conf

    # fail fast if LAPI is unreachable (default 3s adds latency on every miss in live mode)
    sed -i "s|^REQUEST_TIMEOUT=.*|REQUEST_TIMEOUT=500|" \
        /etc/crowdsec/bouncers/crowdsec-nginx-bouncer.conf

    if [ -n "${CROWDSEC_APPSEC_URL:-}" ]; then
        sed -i "s|^APPSEC_URL=.*|APPSEC_URL=${CROWDSEC_APPSEC_URL}|" \
            /etc/crowdsec/bouncers/crowdsec-nginx-bouncer.conf
    fi

    cp /defaults/nginx/templates/crowdsec.conf "${NGINX_CROWDSEC_CONF}"
else
    rm -f "${NGINX_CROWDSEC_CONF}" /etc/crowdsec/bouncers/crowdsec-nginx-bouncer.conf
    echo "CrowdSec credentials not set, nginx bouncer disabled."
fi
