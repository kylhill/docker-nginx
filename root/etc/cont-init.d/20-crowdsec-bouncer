#!/usr/bin/with-contenv bash
# shellcheck shell=bash
set -e

read_secret() {
    var="$1"
    file_var="${var}_FILE"

    if [ -n "${!file_var}" ] && [ -f "${!file_var}" ]; then
        cat "${!file_var}"
    else
        echo "${!var}"
    fi
}

API_KEY="$(read_secret CROWDSEC_NGINX_API_KEY)"
BOUNCER_CONF="/etc/crowdsec/bouncers/crowdsec-nginx-bouncer.conf"
BOUNCER_CONF_TEMPLATE="/etc/crowdsec/bouncers/crowdsec-nginx-bouncer.conf.template"
NGINX_CROWDSEC_INCLUDE="/config/nginx/http.d/crowdsec.conf"
NGINX_CROWDSEC_INCLUDE_DEFAULT="/defaults/nginx/templates/crowdsec.conf"

if [ -n "${API_KEY}" ] && [ -n "${CROWDSEC_LAPI_URL:-}" ]; then
    echo "Configuring CrowdSec nginx bouncer..."

    mkdir -p /config/nginx/http.d

    # The nginx include is static. The bouncer config needs runtime secrets.
    awk \
        -v api_url="${CROWDSEC_LAPI_URL}" \
        -v api_key="${API_KEY}" \
        -v appsec_url="${CROWDSEC_APPSEC_URL:-}" \
        'BEGIN { appsec_written = 0 }
         /^API_URL=/ { print "API_URL=" api_url; next }
         /^API_KEY=/ { print "API_KEY=" api_key; next }
         /^CAPTCHA_PROVIDER=/ { print "CAPTCHA_PROVIDER="; next }
         /^MODE=/ { print "MODE=stream"; next }
         /^REQUEST_TIMEOUT=/ { print "REQUEST_TIMEOUT=500"; next }
         /^APPSEC_URL=/ {
             appsec_written = 1
             if (appsec_url != "") {
                 print "APPSEC_URL=" appsec_url
             } else {
                 print
             }
             next
         }
         { print }
         END {
             if (appsec_url != "" && appsec_written == 0) {
                 print "APPSEC_URL=" appsec_url
             }
         }' \
        "${BOUNCER_CONF_TEMPLATE}" \
        > "${BOUNCER_CONF}"

    install -m 0644 "${NGINX_CROWDSEC_INCLUDE_DEFAULT}" "${NGINX_CROWDSEC_INCLUDE}"
else
    rm -f "${NGINX_CROWDSEC_INCLUDE}" "${BOUNCER_CONF}"
    echo "CrowdSec credentials not set, nginx bouncer disabled."
fi
